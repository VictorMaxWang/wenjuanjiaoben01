{
  "name": "survey-automation-framework",
  "version": "1.0.0",
  "description": "Authorized survey automation framework built with TypeScript and Playwright.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
